{
  "name": "vns",
  "version": "1.0.0",
  "description": "A visual novel script interpreter that transpiles to JavaScript",
  "main": "index.js",
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "rollup": "rollup -c --bundleConfigAsCjs",
    "build": "run compile && npm run rollup",
    "dev": "rollup -c -w --bundleConfigAsCjs"
  },
  "keywords": [
    "visual novel",
    "vnscript",
    "vns",
    "interpreter",
    "javascript"
  ],
  "author": "mkgiga",
  "license": "MIT",
  "dependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4",
    "vns": "file:"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "rollup": "^4.21.2",
    "rollup-plugin-typescript2": "^0.36.0"
  }
}
