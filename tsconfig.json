{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/classes/*": ["./src/class/*"],
      "@/types": ["./src/types"],
      "@/elements/*": ["./src/class/elements/*"],
      "@/util/*": ["./src/util/*"],
      "@/example/*": ["./src/example/*"],
      "@/elements": ["./src/class/elements"],
    },
  },
  "exclude": ["node_modules", "dist", "./tsbuildinfo.json"],
  "watchOptions": {
    "excludeDirectories": ["node_modules", "dist"]
  },
  
  "compileOnSave": true 
}